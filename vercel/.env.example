# Supabase project URL — find in Supabase dashboard → Project Settings → API
SUPABASE_URL=https://YOURPROJECT.supabase.co

# Supabase service-role key (NOT the anon key!) — same dashboard → API → service_role.
# Server-only. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=eyJxxx...

# Random string used to authenticate cron requests.
# Generate one: `openssl rand -hex 32`
CRON_SECRET=replace-with-random-32+-char-string
